    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "jsdom": "^28.0.0",
    "ng-openapi-gen": "^1.0.5",
